# EditorConfig: https://editorconfig.org (design D7 of add-project-skeleton)
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{yml,yaml,toml,json}]
indent_size = 2

[*.md]
indent_size = 2
trim_trailing_whitespace = false
